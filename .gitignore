# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.dev.vars

# vercel
.vercel

# cloudflare / opennext
.open-next
.wrangler
cloudflare-env.d.ts

# typescript
*.tsbuildinfo
next-env.d.ts

# design explorations (探索用、本番に含めない)
/design-explorations/

# claude code workflow markers (一時ファイル、コミット禁止)
/.claude/.simplify-done
/.claude/.review-approved
/.claude/.ship-token

# claude code session-local
.claude/settings.local.json
.claude/scheduled_tasks.lock

# playwright mcp run artifacts (snapshots / console logs)
/.playwright-mcp/

# DM / launch material (local only, do not commit)
/docs/dm/
/docs/screenshots/dm/
